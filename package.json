{
	"name": "type-coverage",
	"version": "0.1.0",
	"description": "Type-level branch coverage for TypeScript conditional types",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"type-coverage": "dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.d.ts",
		"dist/**/*.d.ts.map"
	],
	"scripts": {
		"build": "tsc",
		"build:tests": "tsc -p tests/tsconfig.json",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit && tsc -p tests/tsconfig.json --noEmit",
		"test": "pnpm run build && pnpm run build:tests && node --test dist-tests/tests/**/*.test.js",
		"check-deps": "node scripts/check-deps.js",
		"ci": "pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run test && pnpm run check-deps"
	},
	"keywords": [
		"typescript",
		"type-coverage",
		"conditional-types",
		"static-analysis"
	],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.13.1",
	"peerDependencies": {
		"typescript": ">=5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@types/node": "^25.6.0",
		"typescript": "^6.0.2"
	}
}
